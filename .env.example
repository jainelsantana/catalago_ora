# Production / Coolify Dockerfile deploy.
# In Coolify, copy the PostgreSQL Internal URL from the database resource and
# paste it as DATABASE_URL. Do not paste the example placeholder below as-is.
DATABASE_URL=postgresql://USUARIO:SENHA_URL_ENCODED@HOST_INTERNO_REAL:5432/catalogdb?schema=public
NEXTAUTH_URL=https://catalogo.ora.dev.br
NEXTAUTH_SECRET=gere_um_segredo_longo_e_unico
NEXT_PUBLIC_UPLOAD_API_URL=/api/upload

# Alternative for Coolify if you prefer separate variables instead of DATABASE_URL:
# DATABASE_HOST=HOST_INTERNO_REAL
# DATABASE_PORT=5432
# DATABASE_USER=USUARIO
# DATABASE_PASSWORD=SENHA_SEM_URL_ENCODE
# DATABASE_NAME=catalogdb

# Optional startup tuning.
DB_BOOTSTRAP_RETRIES=30
DB_BOOTSTRAP_RETRY_DELAY_MS=3000

# Optional fallback only if DATABASE_URL still points to db/localhost in production.
# Prefer fixing DATABASE_URL directly.
# DATABASE_FALLBACK_HOST=HOST_INTERNO_DO_POSTGRES

# Important:
# - Use the PostgreSQL internal URL/host from Coolify when app and database are in the same network.
# - Do not use localhost or db as the database host in Coolify Dockerfile deploys.
# - URL-encode special characters in user/password, for example @ as %40.
# - If the value contains $, mark the variable as Literal in Coolify.
# - Do not set RUNNING_IN_DOCKER, USE_COMPOSE_DATABASE_HOST, or SKIP_DB_BOOTSTRAP in Coolify.

# Local Docker Compose reference only.
# The compose file ignores production POSTGRES_* variables and uses these
# COMPOSE_* variables so deploy credentials do not break local containers.
# COMPOSE_POSTGRES_USER=postgres
# COMPOSE_POSTGRES_PASSWORD=postgres
# COMPOSE_POSTGRES_DB=catalogdb
# COMPOSE_POSTGRES_PORT=5432
# COMPOSE_DATABASE_URL=postgresql://postgres:postgres@db:5432/catalogdb?schema=public
# NEXTAUTH_SECRET=troque_para_um_segredo_longo_e_seguro
# NEXTAUTH_URL=http://localhost:3007
# NEXT_PUBLIC_UPLOAD_API_URL=/api/upload

# Local npm run dev reference only:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catalogdb?schema=public
