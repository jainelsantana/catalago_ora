# Docker Compose / local development.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=catalogdb
DATABASE_URL=postgresql://postgres:postgres@db:5432/catalogdb?schema=public
NEXTAUTH_SECRET=troque_para_um_segredo_longo_e_seguro
NEXTAUTH_URL=http://localhost:3007
NEXT_PUBLIC_UPLOAD_API_URL=/api/upload

# If you run `npm run dev` directly on the host, use localhost instead of db:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catalogdb?schema=public

# Coolify Dockerfile deploy:
# - Set these in Coolify as Runtime Variables.
# - Use the PostgreSQL internal host/URL from Coolify, not localhost and not db.
# - URL-encode special characters in user/password, for example @ as %40.
# DATABASE_URL=postgresql://USER:SENHA_URL_ENCODED@HOST_INTERNO_DO_POSTGRES:5432/catalogdb?schema=public
# NEXTAUTH_URL=https://catalogo.ora.dev.br
# NEXTAUTH_SECRET=gere_um_segredo_longo_e_unico
# NEXT_PUBLIC_UPLOAD_API_URL=/api/upload
#
# Optional fallback only if DATABASE_URL still contains db/localhost in production:
# DATABASE_FALLBACK_HOST=HOST_INTERNO_DO_POSTGRES
